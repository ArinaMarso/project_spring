<Window x:Class="StoreG5G11.views.EmployeesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:StoreG5G11.src.modelViews"
        mc:Ignorable="d"
        Title="Управление сотрудниками" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:EmployeeViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="0.8*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Список сотрудников" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <ListBox Grid.Row="1" 
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#BDC3C7" BorderThickness="1" 
                                CornerRadius="5" Margin="0,2" Padding="10">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold" 
                                           Text="{Binding Path=FullName}"/>
                                <TextBlock Text="{Binding Path=Position}" 
                                           Foreground="#2C3E50" FontWeight="SemiBold"
                                           Margin="0,3,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding Path=Salary, StringFormat='Зарплата: {0:C}'}" 
                                               Foreground="#27AE60" FontWeight="Bold"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Path=BirthDate, StringFormat='Рожд.: {0:dd.MM.yyyy}'}" 
                                               Foreground="#3498DB"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Редактирование сотрудника" 
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" 
                    CornerRadius="5" Padding="15" DataContext="{Binding SelectedItem}">
                <StackPanel>
                    <TextBlock Text="Фамилия:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>

                    <TextBlock Text="Имя:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>

                    <TextBlock Text="Отчество:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SecondName, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>

                    <TextBlock Text="Должность:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>

                    <TextBlock Text="Дата рождения (дд.мм.гггг):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding BirthDate, StringFormat='{}{0:dd.MM.yyyy}', UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>

                    <TextBlock Text="Зарплата (руб.):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Salary, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,10" Height="30"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Добавить" Command="{Binding AddCommand}" 
                        Background="#3498DB" Foreground="White"
                        Width="100" Height="35" Margin="5"/>

                <Button Content="Удалить" Command="{Binding RemoveCommand}" 
                        Background="#E74C3C" Foreground="White"
                        Width="100" Height="35" Margin="5"/>

                <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                        Background="#2ECC71" Foreground="White"
                        Width="100" Height="35" Margin="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
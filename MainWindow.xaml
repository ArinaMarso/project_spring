<Window x:Class="StoreG5G11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Music Store - Магазин музыкальных инструментов" 
        Height="499" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="10" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0a0a0a" Padding="20">
            <StackPanel>
                <TextBlock Text="🎵 Music Store" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Магазин музыкальных инструментов" 
                           FontSize="16" 
                           Foreground="#BDC3C7"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center">

            <Button Content="🎸   Управление инструментами" 
                    Click="ManageInstruments_Click"
                    Background="#18171c"
                    Foreground="White"
                    Width="350"/>

            <Button Content="👥   Управление сотрудниками" 
                    Click="ManageEmployees_Click"
                    Background="#18171c"
                    Foreground="White"
                    Width="350"/>

            <Button Content="💰   Продажа инструментов" 
                    Click="SellInstruments_Click"
                    Background="#18171c"
                    Foreground="White"
                    Width="350"/>


        </StackPanel>

        <Border Grid.Row="2" Background="#bdbdbd" Padding="10">
            <TextBlock Text="Music Store v1.0 © 2026" 
                       HorizontalAlignment="Center"
                       Foreground="#0a0a0a"/>
        </Border>
    </Grid>
</Window>